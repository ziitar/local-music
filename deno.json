{
  "imports": {
    "@oak/oak": "jsr:@oak/oak@^17.2.0",
    "@raise/han-convert": "jsr:@raise/han-convert@^2.3.2",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/crypto": "jsr:@std/crypto@^1.0.5",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@tajpouria/cors": "jsr:@tajpouria/cors@^1.2.1",
    "node-taglib-sharp": "npm:node-taglib-sharp@^6.0.0",
    "postgres": "npm:postgres@^3.4.8",
    "bcrypt": "npm:bcrypt@^5.1.1",
    "jwt": "npm:jsonwebtoken@^9.0.2",
    "chardet": "npm:chardet@^2.1.1",
    "cue-parser": "npm:cue-parser@0.3.0"
  },
  "tasks": {
    "dev": "deno run -A npm:vite & deno run server:start:dev",
    "build": "deno run -A npm:vite build",
    "server:start:dev": "deno run -A --env-file --watch ./api/app.ts",
    "server:start": "deno run -A --env-file ./api/app.ts",
    "serve": "deno task build && deno task server:start"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "types": ["react", "react-dom", "@types/react"],
    "lib": ["dom", "dom.iterable", "deno.ns"],
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "unstable": ["raw-imports"],
  "allowScripts": {
    "allow": ["npm:bcrypt@5.1.1"],
    "deny": ["npm:esbuild@0.27.3"]
  }
}
